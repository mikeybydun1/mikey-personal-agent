# Copy this file to ".env" and fill in your real Garmin Connect credentials.
# The ".env" file is gitignored and will never be committed.

GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password-here

# Directory where the OAuth tokens are cached after the first successful login.
# After the first run you normally won't need to send your password again.
GARMIN_TOKEN_STORE=.garmin_tokens

# Where fetched JSON data is written.
GARMIN_DATA_DIR=data

# Garmin China account? (true/false) — almost always false.
GARMIN_IS_CN=false

# ---- OpenAI (for the report-generating agent) ----
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ---- Email delivery (Gmail SMTP) ----
# EMAIL_APP_PASSWORD must be a Gmail "App Password" (Google Account > Security >
# 2-Step Verification > App passwords), NOT your normal account password.
EMAIL_SENDER=you@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_RECIPIENT=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
